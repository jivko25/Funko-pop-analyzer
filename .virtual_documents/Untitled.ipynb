# =====================================================
# 7. Конвертиране на дати
# =====================================================

date_cols = ['created_at', 'published_at', 'updated_at']

for col in date_cols:
    df[col] = pd.to_datetime(df[col], errors='coerce')

# =====================================================
# 8. Работа с липсващи стойности
# =====================================================

# price → ако има липсващи → махаме редовете (важно поле)
df = df.dropna(subset=['price'])

# vendor → запълваме с "Unknown"
df['vendor'] = df['vendor'].fillna('Unknown')

# =====================================================
# 9. Почистване на текстови полета
# =====================================================

df['title'] = df['title'].str.strip()
df['product_type'] = df['product_type'].str.strip()

# =====================================================
# 10. Feature engineering (много важно за DS)
# =====================================================

# брой тагове
df['tags_count'] = df['tags'].apply(lambda x: len(x.split(',')) if x else 0)

# брой лицензи
df['license_count'] = df['license'].apply(lambda x: len(x.split(',')) if x else 0)

# =====================================================
# 11. Премахване на ненужни колони
# =====================================================

cols_to_drop = ['gid', 'handle', 'img']

df = df.drop(columns=cols_to_drop)

